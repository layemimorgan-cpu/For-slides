<!DOCTYPE html>

<html lang="en">
<head>
<meta charset="UTF-8">
<title>Worthly Feature Slides</title>
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,700;0,900;1,700&family=DM+Sans:wght@400;500;600;700&display=swap" rel="stylesheet">
<style>
* { margin:0; padding:0; box-sizing:border-box; }
:root {
  --pink: #E91E8C; --purple: #7B5EA7; --purple-deep: #4B3FD8;
  --dark: #1a1a2e; --mid: #4a4a6a;
}
body {
  background: #ede8f5; font-family: 'DM Sans', sans-serif;
  display: flex; flex-direction: column; align-items: center; gap: 60px; padding: 60px 24px;
}
.label {
  font-size: 11px; font-weight: 700; letter-spacing: 0.12em;
  text-transform: uppercase; color: #999; margin-bottom: 10px; text-align: center;
}
.slide {
  width: 540px; height: 720px;
  border-radius: 0; overflow: hidden; position: relative; flex-shrink: 0;
  background: linear-gradient(150deg, #fce8f6 0%, #ede4fd 45%, #dde4fd 100%);
  box-shadow: 0 24px 60px rgba(75,63,216,0.2), 0 4px 16px rgba(0,0,0,0.08);
}
.blob { position: absolute; border-radius: 50%; filter: blur(60px); opacity: 0.5; }
.b1 { width: 360px; height: 360px; background: #e8b4f8; top: -100px; right: -80px; }
.b2 { width: 220px; height: 220px; background: #b4c8f8; bottom: 40px; left: -60px; }
.b3 { width: 140px; height: 140px; background: #f8b4d8; top: 280px; left: 80px; }
.content {
  position: relative; z-index: 3; padding: 28px 44px 0; text-align: center;
}
.tab-label {
  font-size: 10px; font-weight: 700; letter-spacing: 0.1em; text-transform: uppercase;
  color: var(--purple); background: rgba(255,255,255,0.75); backdrop-filter: blur(8px);
  border: 1px solid rgba(255,255,255,0.9); border-radius: 100px;
  padding: 6px 14px; width: fit-content; margin: 0 auto 14px;
  display: block; white-space: nowrap;
}
.headline {
  font-family: 'Playfair Display', serif; font-size: 26px; font-weight: 900;
  line-height: 1.1; color: var(--dark); margin-bottom: 0; white-space: nowrap;
}
.headline em {
  font-style: italic;
  background: linear-gradient(135deg, var(--pink), var(--purple-deep));
  -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;
}
.phone-wrap {
  position: absolute; bottom: 28px; left: 50%; transform: translateX(-50%);
  width: 278px; z-index: 2;
}
.phone-wrap img {
  width: 100%; border-radius: 36px;
  border: 3px solid rgba(255,255,255,0.7);
  box-shadow: 0 16px 48px rgba(75,63,216,0.2);
}
</style>
</head>
<body>

<div>
  <p class="label">Sinking Funds</p>
  <div class="slide">
    <div class="blob b1"></div>
    <div class="blob b2"></div>
    <div class="blob b3"></div>
    <div class="content">
      <div class="tab-label">✦ Sinking Funds</div>
      <h1 class="headline">Your goals? <em>Fully funded.</em></h1>
    </div>
    <div class="phone-wrap"><img src="data:image/jpeg;base64," alt="Sinking Funds"></div>
  </div>
</div>

<div>
  <p class="label">Investments</p>
  <div class="slide">
    <div class="blob b1"></div>
    <div class="blob b2"></div>
    <div class="blob b3"></div>
    <div class="content">
      <div class="tab-label">✦ Investments</div>
      <h1 class="headline">Track your investments, <em>all in one place.</em></h1>
    </div>
    <div class="phone-wrap"><img src="data:image/jpeg;base64," alt="Investments"></div>
  </div>
</div>

<div>
  <p class="label">Net Worth</p>
  <div class="slide">
    <div class="blob b1"></div>
    <div class="blob b2"></div>
    <div class="blob b3"></div>
    <div class="content">
      <div class="tab-label">✦ Net Worth</div>
      <h1 class="headline">Know your net worth, <em>month by month.</em></h1>
    </div>
    <div class="phone-wrap"><img src="data:image/jpeg;base64," alt="Net Worth"></div>
  </div>
</div>

<div>
  <p class="label">No-Spend Calendar</p>
  <div class="slide">
    <div class="blob b1"></div>
    <div class="blob b2"></div>
    <div class="blob b3"></div>
    <div class="content">
      <div class="tab-label">✦ No-Spend Calendar</div>
      <h1 class="headline">Challenge yourself with <em>no-spend days.</em></h1>
    </div>
    <div class="phone-wrap"><img src="data:image/jpeg;base64," alt="No-Spend Calendar"></div>
  </div>
</div>

<div>
  <p class="label">Wishlist</p>
  <div class="slide">
    <div class="blob b1"></div>
    <div class="blob b2"></div>
    <div class="blob b3"></div>
    <div class="content">
      <div class="tab-label">✦ Wishlist</div>
      <h1 class="headline">Want something? Add it and <em>come back later!</em></h1>
    </div>
    <div class="phone-wrap"><img src="data:image/jpeg;base64," alt="Wishlist"></div>
  </div>
</div>

<div>
  <p class="label">Budget</p>
  <div class="slide">
    <div class="blob b1"></div>
    <div class="blob b2"></div>
    <div class="blob b3"></div>
    <div class="content">
      <div class="tab-label">✦ Budget</div>
      <h1 class="headline">Your spending, <em>finally under control.</em></h1>
    </div>
    <div class="phone-wrap"><img src="data:image/jpeg;base64," alt="Budget"></div>
  </div>
</div>

</body>
</html>
